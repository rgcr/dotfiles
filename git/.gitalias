[alias]
    # short aliases
    st = status
    ch = checkout
    c = commit
    d = diff
    a = add
    p = push
    # show aliases
    alias = config --get-regexp ^alias
    #  ranking of commits
    rank = shortlog -sn --no-merges
    # show pretty log
    lol = log --color --graph --pretty=format:'%C(red)%h%C(reset) %C(green)(%ai)%C(reset) %C(yellow)|%C(reset) %s %C(bold blue)<%an> %C(red)%d' --abbrev-commit
    # show pretty log with relative time
    lh = log --color --graph --pretty=format:'%C(red)%h%C(reset) %C(green)(%ar)%C(reset) %C(yellow)|%C(reset) %s %C(bold blue)<%an> %C(red)%d' --abbrev-commit
    # force pull with rebase and autostash
    pullf = pull --rebase --autostash
    # show files in commits
    show-files = show --name-only --pretty=""
    # change last commit message
    change-commit = commit --amend -m

# vim: ft=gitconfig
